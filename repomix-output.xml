import 'package:supabase_flutter/supabase_flutter.dart';
import '../models/models.dart';

class AuthRepository {
  final supabase = Supabase.instance.client;

  Future<Map<String, dynamic>> login(
    String nik,
    String password,
    String nama,
    DateTime tanggalLahir,
  ) async {
    try {
      final response = await supabase
          .from('penduduk')
          .select()
          .eq('nik', nik)
          .eq('password', password)
          .eq('nama', nama.trim())
          .eq('tanggal_lahir', tanggalLahir.toIso8601String().split('T')[0])
          .maybeSingle();

      if (response == null) {
        return {
          'success': false,
          'message': 'Data tidak cocok. Pastikan semua input benar',
        };
      }

      final penduduk = PendudukModel.fromJson(response);
      final isAdmin = response['role'] == 'admin';

      return {'success': true, 'penduduk': penduduk, 'isAdmin': isAdmin};
    } catch (e) {
      return {'success': false, 'message': 'Terjadi kesalahan: $e'};
    }
  }
}
</file>

